<div id="morph">
  <h1>Todo List</h1>
  <div class="add-form" data-signals:todo_input="">
    <input type="text" placeholder="What needs to be done?" data-bind="todo_input" />
    <button data-on:click="@post('{{ add_path }}')">Add</button>
  </div>
  <div class="todo-list">
    {{ todo_list | safe }}
  </div>
</div>
