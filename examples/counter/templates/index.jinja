<div id="morph">
  <h1>Counter</h1>
  <div class="count">{{ count }}</div>
  <div class="buttons">
    <button id="btn-dec" data-on:click="@post('{{ dec_path }}')">− <kbd>H</kbd></button>
    <button id="btn-reset" data-on:click="@post('{{ reset_path }}')">Reset <kbd>R</kbd></button>
    <button id="btn-inc" data-on:click="@post('{{ inc_path }}')">+ <kbd>L</kbd></button>
  </div>
  <script>
    document.addEventListener('keydown', (e) => {
      if (e.repeat) return;
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      const key = e.key.toLowerCase();
      if (key === 'h') document.getElementById('btn-dec').click();
      else if (key === 'l') document.getElementById('btn-inc').click();
      else if (key === 'r') document.getElementById('btn-reset').click();
    });
  </script>
</div>
