<div id="morph">
  <div class="chat-container">
    <h1>Hyperdream Chat</h1>

    <div class="messages">
      {{ messages | safe }}
    </div>

    <div class="input-bar">
      <input type="text"
             placeholder="Name"
             data-bind="username"
             data-signals:username=""
             class="name-input" />
      <input type="text"
             placeholder="Type a message…"
             data-bind="message"
             data-signals:message=""
             data-on:keydown="if(evt.key==='Enter') @post('{{ send_path }}')"
             class="message-input" />
      <button data-on:click="@post('{{ send_path }}')">Send</button>
    </div>
  </div>

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f0f2f5; }
    .chat-container {
      max-width: 640px; margin: 2rem auto; background: #fff;
      border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.1);
      display: flex; flex-direction: column; height: 80vh;
    }
    h1 { padding: 1rem; border-bottom: 1px solid #e0e0e0; font-size: 1.2rem; }
    .messages {
      flex: 1; overflow-y: auto; padding: 1rem;
      display: flex; flex-direction: column; gap: .4rem;
    }
    .message { padding: .4rem .6rem; background: #f7f7f8; border-radius: 6px; }
    .message strong { color: #1a73e8; }
    .input-bar {
      display: flex; gap: .5rem; padding: 1rem;
      border-top: 1px solid #e0e0e0;
    }
    .name-input { width: 120px; }
    .message-input { flex: 1; }
    input, button {
      padding: .5rem .75rem; border: 1px solid #ccc; border-radius: 4px;
      font-size: .9rem;
    }
    button {
      background: #1a73e8; color: #fff; border: none; cursor: pointer;
    }
    button:hover { background: #1557b0; }
  </style>
</div>
